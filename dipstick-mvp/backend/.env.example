# ============================================================
# Dipstick MVP — Environment Variables
# Copy to .env and fill in as needed.
# ============================================================

# ---------------------------------------------------------------------------
# LLM Explanation Layer (optional)
# If not set, a rule-based template is used instead (works offline).
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------------------------
# InterSystems FHIR Server Integration
# Default values point to the local FHIR-AI-Hackathon-Kit Docker instance.
# ---------------------------------------------------------------------------

# FHIR R4 base endpoint (no trailing slash)
FHIR_BASE_URL=http://localhost:32783/csp/healthshare/demo/fhir/r4

# Master switch — set false to generate bundles locally only (no HTTP calls)
FHIR_POST_ENABLED=true

# Include one Observation per dipstick pad when posting
FHIR_POST_OBSERVATIONS=true

# Per-request timeout in seconds
FHIR_TIMEOUT_SECONDS=10

# Basic Auth — leave blank for the local unauthenticated dev kit
FHIR_USERNAME=
FHIR_PASSWORD=
